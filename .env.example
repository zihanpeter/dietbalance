# ====== 必填 ======
# USDA FoodData Central API Key（免费申请：https://fdc.nal.usda.gov/api-key-signup）
# 不设置时会用 DEMO_KEY，但每 IP 每小时只有 30 次
USDA_API_KEY=

# ====== 可选 ======
# Web 端口（PaaS 通常会自动注入，如 Render / Railway）
PORT=8000

# Gunicorn worker 数，一般设为 CPU 核数
WEB_CONCURRENCY=2

# Gunicorn 日志级别：debug / info / warning / error
GUNICORN_LOGLEVEL=info

# 本地开发可打开 Flask 调试
# FLASK_DEBUG=1

# Cloudflare Tunnel Token
CLOUDFLARE_TUNNEL_TOKEN=
